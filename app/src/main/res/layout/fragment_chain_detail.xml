<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Chain header -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/detailId"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_avatar"
                android:gravity="center"
                android:textColor="@color/accent"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/detailName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detailDiff"
                style="@style/Chip.Diff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Info rows -->
        <include layout="@layout/row_info" android:id="@+id/rowCategory" />
        <include layout="@layout/row_info" android:id="@+id/rowObjective" />
        <include layout="@layout/row_info" android:id="@+id/rowHint" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
