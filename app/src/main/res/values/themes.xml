<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.MoChat" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/tag_fg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Let content draw behind status/nav bars; insets are handled per-layout. -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Base text styles (parents for the dot-notation variants) -->
    <style name="Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Chip">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Buttons: outlined on dark background (default Material fills with colorPrimary) -->
    <style name="MoButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="MoButton.Accent" parent="MoButton">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="strokeColor">@color/accent</item>
    </style>

    <!-- Header text -->
    <style name="Text.Header">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Text.Subtle">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Chain card texts -->
    <style name="Text.ChainId">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="Text.ChainName">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.ChainComponent">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="Text.ChainModern">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Chips -->
    <style name="Chip.Diff">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:minWidth">64dp</item>
    </style>

</resources>
